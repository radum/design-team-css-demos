---
import RootLayout from '../layouts/RootLayout.astro';
import DemoLayout from '../layouts/DemoLayout.astro';
---

<script type="module"></script>

<style is:global>
	/**
    * Custom Select Demo - Application Styles
    *
    * This stylesheet handles page layout and global styles.
    * Component-specific styles are in select/select.css.
    */

	/* =============================================================================
   EXTERNAL DEPENDENCIES
   ============================================================================= */

	/* Open Props provides CSS custom properties for animations */
	@import 'https://unpkg.com/open-props/easings.min.css';
	@import 'https://unpkg.com/open-props/durations.min.css';

	/* Select component styles */
	/**
    * CustomSelect Component Styles
    *
    * A custom select dropdown with aligned opening animation.
    * The selected option aligns with the button when the picker opens.
    *
    * Key CSS features used:
    * - appearance: base-select (enables custom select styling)
    * - CSS Anchor Positioning (picker positioned relative to button)
    * - CSS Custom Properties (--_select-anchor-offset from JavaScript)
    * - Container Queries with scroll-state() (sticky legend detection)
    * - @starting-style (entry animations for popover)
    *
    * All layout uses logical properties for RTL/writing-mode support.
    */

	/* =============================================================================
   DESIGN TOKENS
   ============================================================================= */

	select {
		/* Spacing */
		--_select-space: 8px;
		--_select-space-xs: 4px;
		--_select-space-xxs: 2px;

		/* Shared dimensions */
		--_select-item-h: 36px;
		--_select-picker-r: 10px;
		--_select-option-r: 6px;
		--_select-icon-size: 16px;
		--_select-check-size: 14px;
		--_select-max-w: 220px;
		--_select-max-h: min(380px, 80dvh);

		/* Scale values for animations */
		--_select-scale-open: 1.04;
		--_select-scale-press: 0.98;
		--_select-scale-start: 0.9;

		/* Animation timing (imported from Open Props) */
		--_select-dur-in: var(--duration-gentle-1);
		--_select-dur-out: var(--duration-quick-2);

		/* Colors - adaptive to light/dark mode via system colors */
		--_select-bg: light-dark(white, oklch(20% none none));
		--_select-border: color-mix(in srgb, CanvasText 15%, transparent);
		--_select-hover-bg: color-mix(in srgb, CanvasText 4%, transparent);
		--_select-shadow: rgb(0 0 0 / 0.1);
		--_select-scrollbar: color-mix(in srgb, CanvasText 30%, transparent);
		--_select-icon: color-mix(in srgb, CanvasText 55%, transparent);

		/* Icons by color */
		--_select-chevron-black: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="black" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>');
		--_select-chevron-white: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>');
		--_select-check-black: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="%23000" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>');
		--_select-check-white: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>');
		--_select-check-canvas: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="Canvas" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>');

		@media (prefers-color-scheme: dark) {
			--_select-shadow: rgb(0 0 0 / 0.5);
			--_select-hover-bg: color-mix(in srgb, CanvasText 10%, transparent);
		}
	}

	/* =============================================================================
   SELECT BUTTON (CLOSED STATE)
   ============================================================================= */

	select {
		/* Enable custom select styling - this is the magic property */
		/* Picker also needs base-select appearance */
		@media (hover) and (pointer: fine) {
			&,
			&::picker(select) {
				appearance: base-select;
			}
		}

		max-inline-size: var(--_select-max-w);
		font: inherit;
		place-items: center;
		border-radius: var(--_select-option-r);
		background: var(--_select-bg);
		border: 1px solid var(--_select-border);
		box-shadow: 0 0 0 0 color-mix(in srgb, CanvasText 8%, transparent);
		padding-block: 0;
		padding-inline: var(--_select-space-xs);

		will-change: scale; /* fixes text shift */
		transition:
			box-shadow 0.2s ease,
			scale calc(var(--_select-dur-in) * 2) var(--ease-spring-3);

		/* Squircle corners for modern browsers */
		@supports (corner-shape: squircle) {
			corner-shape: superellipse(1.25);
			border-radius: 20px;
		}

		/* iOS fix so it doesnt zoom */
		@supports (-webkit-touch-callout: none) {
			font-size: 16px;
		}

		/* Open state - subtle scale up for depth effect */
		&:open {
			scale: var(--_select-scale-open);
		}

		/* Hover - subtle shadow halo effect for light mode, but dark mode has a background color */
		&:hover {
			background-color: Canvas;

			@media (prefers-color-scheme: light) {
				box-shadow: 0 0 0 var(--_select-space-xs) color-mix(in srgb, CanvasText 5%, transparent);
			}

			@media (prefers-color-scheme: dark) {
				background-color: color-mix(in srgb, CanvasText 10%, transparent);
			}
		}

		/* Focus states */
		&:focus {
			outline: 2px solid color-mix(in srgb, Highlight 50%, transparent);
			outline-offset: 2px;
		}

		&:focus-visible {
			outline: 2px solid Highlight;
			outline-offset: 3px;
		}
	}

	/* =============================================================================
   BUTTON TRIGGER
   ============================================================================= */

	select > button {
		display: flex;
		align-items: center;
		gap: var(--_select-space);
		inline-size: 100%;
		block-size: var(--_select-item-h);
		padding-inline: var(--_select-space);
		background: transparent;
		color: CanvasText;
		border: none;
		border-radius: var(--_select-option-r);

		-webkit-tap-highlight-color: transparent;
		transition: transform 0.1s ease;

		&:active {
			transform: scale(var(--_select-scale-press));
		}
	}

	/* =============================================================================
   PICKER ICON (CHEVRON)
   ============================================================================= */

	/**
 * The picker icon rotates 180° when open.
 * Uses spring easing for a playful, physical feel.
 */
	select::picker-icon {
		content: var(--_select-chevron-black);
		inline-size: var(--_select-icon-size);
		block-size: var(--_select-icon-size);
		aspect-ratio: 1;
		margin-inline-end: var(--_select-space);
		opacity: 0.75;
		transition:
			transform calc(var(--_select-dur-in) * 3) var(--ease-spring-3),
			opacity 0.15s;

		@media (prefers-color-scheme: dark) {
			content: var(--_select-chevron-white);
		}
	}

	select:hover::picker-icon {
		opacity: 0.8;
	}

	select:open::picker-icon {
		transform: rotate(180deg);
		opacity: 1;
	}

	/* =============================================================================
   PICKER DROPDOWN
   ============================================================================= */

	/**
 * The picker uses CSS Anchor Positioning to align with the button.
 *
 * Key alignment mechanism:
 * - inset-block-start: calc(anchor(start) - var(--_select-anchor-offset))
 *   Moves picker up so selected option aligns with button
 * - transform-origin: 50% var(--_select-anchor-offset)
 *   Scales from the selected option's position for smooth animation
 *
 * The --_select-anchor-offset is calculated by JavaScript and set as an
 * inline style on the select element.
 */
	select::picker(select) {
		overflow: clip;

		/* Anchor positioning - align selected option with button */
		inset-block-start: calc(anchor(start) - var(--_select-anchor-offset));
		inset-inline-start: calc(anchor(start) - var(--_select-space));

		/* Sizing - at least as wide as button, with some base width */
		min-inline-size: calc(anchor-size(inline) + var(--_select-icon-size));
		max-block-size: var(--_select-max-h);
		margin: 0;
		padding-block: var(--_select-space);
		padding-inline-end: var(--_select-space-xs);

		/* Fallback when aligned position overflows viewport */
		position-try: flip-block, flip-inline;

		/* Scale animation origin - aligned with selected option offset */
		transform-origin: 50% var(--_select-anchor-offset);

		/* Appearance */
		background-clip: padding-box;
		border: 1px solid var(--_select-border);
		border-radius: var(--_select-picker-r);
		background-color: var(--_select-bg);
		box-shadow:
			0 10px 15px -3px var(--_select-shadow),
			0 4px 6px -4px var(--_select-shadow);

		@supports (corner-shape: squircle) {
			corner-shape: superellipse(1.25);
			border-radius: 25px;
		}

		/* Open state animation */
		opacity: 1;
		will-change: scale;
		transition:
			display var(--_select-dur-in) allow-discrete,
			overlay var(--_select-dur-in) allow-discrete,
			opacity var(--_select-dur-in) ease,
			scale calc(var(--_select-dur-in) * 2) var(--ease-spring-3);
	}

	select[dir='rtl']::picker(select) {
		inset-inline-end: calc(anchor(start) - 40px);
	}

	/* Closed state - fade and scale down */
	select::picker(select):not(:popover-open) {
		opacity: 0;
		scale: var(--_select-scale-press);
		transition-duration: var(--_select-dur-out);
	}

	/**
 * Entry animation using @starting-style.
 * This defines the initial state before the popover becomes visible.
 * Without this, the picker would appear instantly without animation.
 */
	@starting-style {
		select::picker(select):popover-open {
			opacity: 0;
			scale: var(--_select-scale-start);
		}
	}

	/* =============================================================================
   OPTIONS
   ============================================================================= */
	@keyframes select-option-enter {
		from {
			opacity: 0;
		}
	}

	select option {
		display: flex;
		align-items: center;
		gap: var(--_select-space);
		margin-inline: 0;
		block-size: var(--_select-item-h);
		padding-inline: var(--_select-space);
		padding-inline-end: 12px;
		border: 1px solid transparent;
		border-radius: var(--_select-option-r);
		position: relative;
		transition: background 0.15s;

		@media (prefers-reduced-motion: no-preference) {
			@supports (animation-timeline: view()) {
				animation: select-option-enter both;
				animation-timeline: view();
				animation-range: entry 50% entry 100%;
			}
		}

		/* Gap between options (except last) */
		&:not(:last-of-type) {
			margin-block-end: var(--_select-space-xxs);
		}

		@supports (corner-shape: squircle) {
			corner-shape: superellipse(1.25);
			border-radius: 20px;
		}

		&:hover:where(:not([disabled])) {
			background: var(--_select-hover-bg);
		}

		/* Selected/checked state */
		&:checked {
			background: Highlight;
			color: HighlightText;

			@media (forced-colors: active) {
				background: Canvas;
				border-color: Highlight;
				color: Highlight;
			}

			& .icon {
				stroke: currentColor;
			}
		}
	}

	/* =============================================================================
   CHECKMARK
   ============================================================================= */

	/**
 * The checkmark appears on the selected option.
 */
	select option::checkmark {
		order: 2;
		margin-inline-start: auto;
		content: var(--_select-check-black);
		inline-size: var(--_select-check-size);
		block-size: var(--_select-check-size);
		aspect-ratio: 1;

		@media (prefers-color-scheme: dark) {
			content: var(--_select-check-black);
		}

		@media (forced-colors: active) {
			content: var(--_select-check-canvas);

			@media (prefers-color-scheme: dark) {
				content: var(--_select-check-white);
			}
		}
	}

	/* =============================================================================
   ICONS
   ============================================================================= */

	select .icon {
		inline-size: var(--_select-icon-size);
		block-size: var(--_select-icon-size);
		fill: none;
		stroke: var(--_select-icon);
		stroke-width: 1.5;
		stroke-linecap: round;
		stroke-linejoin: round;
		flex-shrink: 0;
	}

	/* =============================================================================
   OPTGROUP GROUPS
   ============================================================================= */

	select optgroup {
		display: grid;
		border: none;
		margin: 0;
		padding: 0;

		/* Border separator between optgroups */
		&:not(:first-of-type) {
			border-block-start: 1px solid var(--_select-border);
		}

		/* Gap after optgroups (except last) */
		&:not(:last-of-type) {
			padding-block-end: var(--_select-space);
		}
	}

	/* =============================================================================
   LEGENDS (GROUP HEADERS)
   ============================================================================= */

	/**
 * Legends are sticky headers that stay visible when scrolling.
 * Uses container queries with scroll-state(stuck) to detect when
 * the legend is stuck to the top, changing its text color for emphasis.
 */
	select legend {
		float: inline-start;
		inline-size: 100%;
		position: sticky;
		inset-block-start: 0;
		z-index: 1;

		/* Text trimming for precise vertical alignment */
		text-box: trim-both cap alphabetic;

		padding-block: 12px 6px;
		padding-inline: 10px;
		background: var(--_select-bg);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.15em;

		/* Enable scroll-state container queries */
		container-type: scroll-state;

		& span {
			display: inline-flex;
			align-items: center;
			gap: var(--_select-space-xs);
			color: color-mix(in srgb, CanvasText 50%, transparent);
			transition: color 0.3s ease;

			/**
     * When the legend becomes "stuck" (sticky positioned at top),
     * make the text more prominent to indicate scroll context.
     */
			@container scroll-state(stuck) {
				color: CanvasText;

				@media (forced-colors: active) {
					color: Highlight;
				}
			}
		}
	}

	/* =============================================================================
   SELECTED CONTENT (IN BUTTON)
   ============================================================================= */

	select selectedcontent {
		display: flex;
		align-items: center;
		gap: var(--_select-space);
		flex: 1;
		min-inline-size: 0;

		/* Text overflow handling */
		& span {
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
		}

		/* Hide checkmark in button display */
		&::checkmark {
			display: none;
		}

		& .icon {
			stroke: currentColor;
			opacity: 0.6;
		}
	}

	/* Padding adjustment when no icon present */
	select > button > selectedcontent:not(:has(svg)) {
		padding-inline-start: var(--_select-space-xs);
	}

	/* =============================================================================
   LIST CONTAINER
   ============================================================================= */

	/**
 * The scrollable container for options.
 * Uses scroll-state container queries for legend sticky detection.
 */
	select .list {
		container-type: scroll-state;

		padding-inline: var(--_select-space) var(--_select-space-xs);
		overflow: hidden auto;
		max-block-size: calc(var(--_select-max-h) - var(--_select-space) * 2);
		min-inline-size: max-content;

		/* Subtle scrollbar styling */
		scrollbar-width: thin;
		scrollbar-color: var(--_select-scrollbar) transparent;
		transition: scrollbar-color 0.5s ease;
		overscroll-behavior-block: contain;

		@media (prefers-reduced-motion: no-preference) {
			scroll-behavior: smooth;
		}

		/* Fade scrollbar when not hovering */
		&:not(:hover) {
			scrollbar-color: color-mix(in srgb, var(--_select-scrollbar), transparent 50%) transparent;
		}
	}

	/* =============================================================================
   SCROLLABLE STATE ADAPTATIONS
   ============================================================================= */

	/**
 * When content exceeds max-height, JavaScript adds .scrollable class.
 * These rules adjust spacing to accommodate the scrollbar and prevent
 * awkward gaps at the bottom of the picker.
 */

	/* Picker needs more inline padding for scrollbar */
	select.scrollable::picker(select) {
		padding-inline-end: var(--_select-space);
	}

	/* List needs matching inline padding */
	select.scrollable .list {
		padding-inline-end: var(--_select-space);
	}

	/* Last optgroup gets minimal padding to avoid excess bottom space */
	select.scrollable optgroup:last-of-type {
		padding-block-end: var(--_select-space-xxs);
	}

	/* =============================================================================
   GLOBAL SETTINGS
   ============================================================================= */

	:root {
		/* Enable automatic light/dark mode switching */
		color-scheme: light dark;
	}

	/* =============================================================================
   PAGE LAYOUT
   ============================================================================= */

	.demo {
		/* Reset */
		margin: 0;
		padding-block: max(100px, 25vh);
		padding-inline: max(50px, 15vw);
		box-sizing: border-box;

		/* Centered column layout for demo */
		display: grid;
		grid-template-columns: repeat(auto-fit, 25ch);
		place-content: center;
		place-items: start;
		gap: 24px;

		/* Full viewport height */
		min-block-size: 100dvb;

		/* Typography */
		font-family:
			system-ui,
			-apple-system,
			sans-serif;
		font-size: 14px;

		/* System colors adapt to color scheme */
		background: light-dark(oklch(98% none none), oklch(10% none none));
		color: CanvasText;
	}

	/**
 * Example-specific styles
 *
 * These styles support the additional select examples.
 * Review and move into select.css as needed.
 */

	/* =============================================================================
   COLORSPACE SELECT - Button Label
   ============================================================================= */

	select.colorspace-select {
		@supports (appearance: base-select) {
			min-block-size: 3lh;
		}
	}

	select.colorspace-select > button {
		display: grid;
		gap: 0;
	}

	select.colorspace-select > button .label {
		font-size: 8px;
		opacity: 0.6;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding-inline-start: 4px;
		margin-block-end: -1em;
	}

	/* =============================================================================
   PERSON SELECT - Avatars
   ============================================================================= */

	select.person-select {
		button {
			padding-inline-start: 0;
		}

		.avatar {
			inline-size: 24px;
			block-size: 24px;
			border-radius: 50%;
			object-fit: cover;
			flex-shrink: 0;
		}
	}

	/* =============================================================================
   TOGGLE SELECT - Indicators
   ============================================================================= */

	select.toggle .indicator {
		inline-size: 8px;
		block-size: 8px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	select.toggle .indicator.on {
		background: #51cf66;
	}

	select.toggle .indicator.off {
		background: #ff6b6b;
	}

	select.toggle .indicator.disabled {
		background: #e0e0e0;
	}

	/* =============================================================================
   STATUS SELECT - Descriptions
   ============================================================================= */

	select.status-select {
		@supports (appearance: base-select) {
			min-block-size: 3lh;
		}
	}

	select.status-select .custom-option {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	select.status-select .custom-option .description {
		font-size: 11px;
		opacity: 0.6;
	}

	/* Adjust option height for multi-line content */
	select.status-select option:has(.custom-option) {
		block-size: auto;
		min-block-size: var(--item-height);
		padding-block: 8px;
	}
</style>

<RootLayout>
