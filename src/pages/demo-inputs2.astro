			<select>
				<button>
					<selectedcontent></selectedcontent>
				</button>
				<div class="list">
					<optgroup label="Priority">
						<legend><span>Priority</span></legend>
						<option value="urgent">
							<svg class="icon" viewBox="0 0 24 24">
								<path d="M12 9v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
							</svg>
							<span>Urgent</span>
						</option>
						<option value="high">
							<svg class="icon" viewBox="0 0 24 24">
								<path d="m4.5 15.75 7.5-7.5 7.5 7.5"></path>
							</svg>
							<span>High</span>
						</option>
