							</svg>
							<span>High</span>
						</option>
						<option value="medium">
							<svg class="icon" viewBox="0 0 24 24"><path d="M5 12h14"></path></svg>
							<span>Medium</span>
						</option>
						<option value="low" selected>
							<svg class="icon" viewBox="0 0 24 24">
								<path d="m4.5 8.25 7.5 7.5 7.5-7.5"></path>
							</svg>
							<span>Low</span>
						</option>
					</optgroup>
